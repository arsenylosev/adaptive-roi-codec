# Copy to `.env` and fill in your Yandex Cloud values.
# Never commit `.env` — it is listed in `.gitignore`.

# Datasphere project ID (copy from the DataSphere UI)
DATASPHERE_PROJECT_ID=

# DataSphere S3 connector *resource ID* (Project resources → S3 Connector → open resource → ID).
# Not the service account ID, bucket name, or mount name. See docs/guides/datasphere-s3-connector.md.
S3_CONNECTOR_ID=

# Prefix inside the mounted bucket where Kvasir-Capsule lives
S3_DATA_PREFIX=kvasir-capsule

# Checkpoint subdirectory inside the same bucket mount
S3_CHECKPOINT_SUBDIR=checkpoints

# Optional job metadata
DATASPHERE_JOB_NAME=vae-capsule-train
DATASPHERE_JOB_DESC=VAE codec training on Kvasir-Capsule with adaptive ROI quantization

# Extended working directory size for Datasphere Jobs (100–10240 GB)
DATASPHERE_WORKING_STORAGE_GB=150

# Object Storage credentials (for LOCAL upload via AWS CLI / yc — not used inside Datasphere Jobs).
# Jobs access the bucket through S3_CONNECTOR_ID. You may use the same service account key for both.
# Create via: yc iam access-key create --service-account-name <name>
# IMPORTANT: use output key_id → AWS_ACCESS_KEY_ID, secret → AWS_SECRET_ACCESS_KEY (not access_key.id)
# AWS_DEFAULT_REGION=ru-central1 is REQUIRED; other regions cause SignatureDoesNotMatch
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-central1
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_BUCKET=

# Yandex Cloud folder / cloud (for yc CLI)
YC_FOLDER_ID=
YC_CLOUD_ID=

# Local debugging only
TRAIN_DRY_RUN=0
TRAIN_DEVICE=cpu
